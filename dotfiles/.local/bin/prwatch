#!/usr/bin/env zx
// vim: set ft=javascript :
$.verbose = false; // don't echo the gh commands we run

if (argv.help || argv.h) {
  console.log(
    [
      'prwatch — watch a PR’s state, checks, and conversation.',
      '',
      'Usage:',
      '  prwatch                 # PR for current branch',
      '  prwatch 1234            # PR #1234 in current repo',
      '  prwatch owner/repo#1234 # PR in another repo',
      '  prwatch <pr-url>',
      '  prwatch -i 60           # poll every 60s (default 30)',
      '  prwatch --once          # print one snapshot and exit',
    ].join('\n'),
  );
  process.exit(0);
}

const interval = Number(argv.i ?? argv.interval ?? 30);
const once = Boolean(argv.once);
const prArg = argv._[0] ? String(argv._[0]) : '';

const JSON_FIELDS =
  'number,url,title,state,mergeable,mergeStateStatus,reviewDecision,statusCheckRollup,headRefName,baseRefName,isDraft,id';

const FAIL_STATES = new Set([
  'FAILURE',
  'TIMED_OUT',
  //'CANCELLED',
  'ACTION_REQUIRED',
  'STARTUP_FAILURE',
  'ERROR',
]);

const GREEN_STATES = new Set([
  'SUCCESS',
  'SKIPPED',
  'CANCELLED',
]);

async function fetchPr() {
  const args = ['pr', 'view'];
  if (prArg) args.push(prArg);
  args.push('--json', JSON_FIELDS);
  const out = await $`gh ${args}`.nothrow();
  return out.exitCode === 0 ? out.json() : null;
}

async function fetchNode(prId) {
  const query = `
    query($id: ID!) {
      node(id: $id) {
        ... on PullRequest {
          isInMergeQueue
          mergeQueueEntry { position state }
          reviewThreads(first: 100) {
            nodes { isResolved }
          }
        }
      }
    }`;
  const out = await $`gh api graphql -f query=${query} -f id=${prId}`.nothrow();
  if (out.exitCode !== 0) return null;
  const node = out.json()?.data?.node;
  if (!node) return null;
  const nodes = node.reviewThreads?.nodes ?? [];
  return {
    unresolved: nodes.filter((n) => !n.isResolved).length,
    inQueue: Boolean(node.isInMergeQueue),
    queuePosition: node.mergeQueueEntry?.position ?? null,
  };
}

function ring() {
  process.stdout.write('\x07');
}

function deriveStatus({state, mergeable, mergeStatus, decision, isDraft, checksFail, checksPending, inQueue}) {
  if (state === 'MERGED') return 'MERGED';
  if (state === 'CLOSED') return 'CLOSED';
  if (isDraft) return 'DRAFT';
  if (inQueue) return 'QUEUED';
  if (mergeable === 'CONFLICTING') return 'CONFLICT';
  switch (mergeStatus) {
    case 'CLEAN':
    case 'BEHIND':
    case 'HAS_HOOKS':
      return 'READY';
    case 'UNSTABLE':
      return 'UNSTABLE';
    case 'DIRTY':
      return 'CONFLICT';
    case 'DRAFT':
      return 'DRAFT';
    case 'BLOCKED':
      if (decision === 'REVIEW_REQUIRED' || decision === 'CHANGES_REQUESTED') return 'BLOCKED:review';
      if (checksFail > 0 || checksPending > 0) return 'BLOCKED:checks';
      return 'BLOCKED';
    default:
      return 'UNKNOWN';
  }
}

function colorizeStatus(s) {
  if (s === 'READY') return chalk.green(s);
  if (s === 'MERGED') return chalk.blue(s);
  if (s.startsWith('QUEUED')) return chalk.yellow(s);
  if (s === 'CLOSED' || s === 'CONFLICT') return chalk.red(s);
  if (s === 'DRAFT' || s === 'UNKNOWN') return chalk.dim(s);
  if (s === 'UNSTABLE' || s.startsWith('BLOCKED')) return chalk.red(s);
  return s;
}

const initial = await fetchPr();
if (!initial) {
  console.error('No PR found.');
  process.exit(1);
}

const {id: prId, title, url, headRefName, baseRefName, isDraft, number} = initial;

console.log(chalk.bold(title));
console.log(chalk.dim(`${headRefName} → ${baseRefName}${isDraft ? '  (draft)' : ''}`));
console.log(chalk.dim(url));
console.log(chalk.dim(`https://app.graphite.com/github/pr/Tactiq-HQ/main/${number}`));

let prevStatus = '';
let prevUnresolved = -1;
let prevFailedChecks = '';
let data = initial;
let first = true;

while (true) {
  if (!first) {
    await sleep(interval * 1000);
    const next = await fetchPr();
    if (!next) {
      console.log(`${chalk.dim(new Date().toLocaleTimeString())}  ${chalk.yellow('fetch failed')}`);
      continue;
    }
    data = next;
  }
  first = false;

  const state = data.state;
  const mergeable = data.mergeable ?? 'UNKNOWN';
  const mergeStatus = data.mergeStateStatus ?? 'UNKNOWN';
  const decision = data.reviewDecision || 'NONE';

  //console.log(data);

  const node = await fetchNode(prId);
  let unresolved = node?.unresolved ?? prevUnresolved;
  const inQueue = node?.inQueue ?? false;
  const queuePosition = node?.queuePosition ?? null;

  const rollup = data.statusCheckRollup ?? [];
  const stateOf = (c) => c.conclusion ?? c.state;
  const checksPass = rollup.filter((c) => GREEN_STATES.has(stateOf(c))).length;

  const failing = rollup.filter((c) => FAIL_STATES.has(stateOf(c)));
  const checksFail = failing.length;
  const checksPending = rollup.length - checksPass - checksFail;
  const failedChecks = [...new Set(failing.map((c) => c.name ?? c.context ?? '?'))].sort().join(', ');

  //console.log(rollup.filter((c) => stateOf(c) !== 'SUCCESS' && stateOf(c) !== 'SKIPPED'));

  const prStatus = deriveStatus({state, mergeable, mergeStatus, decision, isDraft, checksFail, checksPending, inQueue});
  const statusC = prStatus === 'QUEUED' && queuePosition != null
    ? colorizeStatus(`${prStatus}#${queuePosition}`)
    : colorizeStatus(prStatus);

  let checksC;
  if (checksFail > 0) {
    checksC = `${chalk.red(`⨯${checksFail}`)}`;
  } else if (checksPending > 0) {
    checksC = `${chalk.yellow(checksPending.toString().padStart(2, ' '))}:${chalk.green(checksPass)}`;
  } else {
    checksC = chalk.green(checksPass);
  }

  const unresolvedC = chalk[unresolved > 0 ? 'red' : 'green'](`•${unresolved}`);
  const ts = new Date().toLocaleTimeString();
  console.log(`${chalk.dim(ts)} ${checksC} ${unresolvedC} ${statusC} `);

  if (prevStatus && prStatus !== 'UNKNOWN' && prevStatus !== 'UNKNOWN' && prStatus !== prevStatus) {
    ring();
  }

  prevStatus = prStatus;
  prevUnresolved = unresolved;
  prevFailedChecks = failedChecks;

  if (state === 'MERGED' || state === 'CLOSED') {
    console.log();
    console.log(`PR is ${state} — exiting.`);
    ring();
    process.exit(0);
  }

  if (once) process.exit(0);
}

